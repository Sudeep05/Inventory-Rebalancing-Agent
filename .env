# LLM API Keys — system tries Gemini first, then Groq, then Claude
# You need at least ONE working key.

# Google Gemini (primary) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq (fast fallback, free) — https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# Anthropic Claude (optional) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here
